{
  "name": "pdf2img",
  "displayName": "PDF to Images",
  "description": "Convert PDF files to images and copy any page image with right-click",
  "version": "1.0.0",
  "license": "SEE LICENSE IN LICENSE",
  "publisher": "anjaneykumar",
  "repository": {
    "type": "git",
    "url": "https://github.com/anjaneykumar7/pdf2img-vscode.git"
  },
  "homepage": "https://github.com/anjaneykumar7/pdf2img-vscode#readme",
  "bugs": {
    "url": "https://github.com/anjaneykumar7/pdf2img-vscode/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "pdf",
    "image",
    "pdf to image",
    "pdf viewer",
    "pdf preview",
    "pdf converter",
    "pdf gallery",
    "copy image",
    "pdf2img",
    "document viewer"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pdf2img.convertPdf",
        "title": "PDF to Images: Convert PDF"
      },
      {
        "command": "pdf2img.copyImage",
        "title": "Copy Image"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "pdf2img.convertPdf",
          "when": "resourceExtname == .pdf",
          "group": "navigation"
        }
      ],
      "webview/context": [
        {
          "command": "pdf2img.copyImage",
          "when": "(webviewId == 'pdf2img.preview' || webviewId == 'pdf2img.pdfPreview') && webviewSection == 'image'"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "pdf2img.pdfPreview",
        "displayName": "PDF to Images",
        "selector": [
          {
            "filenamePattern": "*.pdf"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "pdfjs-dist": "^4.0.379"
  }
}
